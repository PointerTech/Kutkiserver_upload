<odoo>
    <record id="view_move_form_inherit_old_bill" model="ir.ui.view">
        <field name="name">account.move.form.inherit.old.bill</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">

            <!-- Add after invoice_date -->
            <xpath expr="//field[@name='invoice_date']" position="after">
                <field name="old_bill_number"/>
            </xpath>

        </field>
    </record>
    <!-- for list view -->
    <record id="view_move_tree_inherit_old_bill" model="ir.ui.view">
        <field name="name">account.move.tree.inherit.old.bill</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_out_invoice_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_date']" position="after">
                <field name="old_bill_number" optional ="hide"/>
            </xpath>
        </field>
    </record>

    <!-- SEARCH VIEW -->
    <record id="view_move_filter_inherit_old_bill" model="ir.ui.view">
        <field name="name">account.move.search.inherit.old.bill</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_account_move_filter"/>
        <field name="arch" type="xml">

            <xpath expr="//search" position="inside">
                <field name="old_bill_number"/>
            </xpath>

        </field>
    </record>

    <!-- Optional if needed in printed vendor bill -->
